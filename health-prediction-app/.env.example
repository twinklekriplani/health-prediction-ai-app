# MIRA Configuration File Template
# Copy this file to a new file named '.env' in the same folder.
# By default, MIRA will use its local clinical predictive model if keys are blank.

# Optional: Google Gemini API Key for advanced AI remarks
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key for advanced AI remarks
OPENAI_API_KEY=your_openai_api_key_here
